# {{SERVICE_NAME}} — Environment Variables
# Copy this file to .env and fill in real values
# Never commit .env to version control

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# Cosmos DB ({{DATABASE}})
# ─────────────────────────────────────────────
COSMOS_ENDPOINT=https://{{SERVICE_NAME}}-cosmos-dev.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key-here
COSMOS_DATABASE={{SERVICE_NAME}}-db

# ─────────────────────────────────────────────
# Azure
# ─────────────────────────────────────────────
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
DYNATRACE_API_TOKEN=your-dt-token
APPLICATIONINSIGHTS_CONNECTION_STRING=your-appinsights-connection-string
